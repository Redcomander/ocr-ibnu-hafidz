# OCR service
PORT=3099

# Auth mode:
# - none: OCR API open (local/dev only)
# - main-jwt: require bearer token from Ibnu Hafidz main web
OCR_AUTH_MODE=main-jwt

# Option A: verify token directly using main app JWT signing key
MAIN_JWT_SECRET=change-me

# Option B (recommended): verify token against main backend /api/auth/me
# Leave empty to use MAIN_JWT_SECRET path.
MAIN_AUTH_ME_URL=http://localhost:8080/api/auth/me
